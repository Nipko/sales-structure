# ============================================
# Parallext Engine — Environment Variables
# Copy this file as .env and fill in the values
# ============================================

# ---- General ----
NODE_ENV=development
LOG_LEVEL=debug

# ---- Authentication ----
# Shared JWT secret between API and WhatsApp services (min 32 chars)
INTERNAL_JWT_SECRET=your_jwt_secret_here_min_32_chars
# JWT token expiration
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ---- Database ----
DATABASE_URL=postgresql://parallext:parallext_secret@localhost:5432/parallext_engine
DB_PASSWORD=parallext_secret

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- API Service (port 3000) ----
API_PORT=3000
DASHBOARD_URL=http://localhost:3001

# ---- WhatsApp Service (port 3002) ----
WA_PORT=3002

# ---- Encryption ----
# 64-char hex string (32 bytes) for AES-256-GCM encryption of channel tokens
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_64_char_hex_encryption_key_here

# ---- Internal Service-to-Service Communication ----
# Base URL for the API as seen from the WhatsApp microservice (docker service name)
API_INTERNAL_URL=http://api:3000/api/v1
# Shared secret for service-to-service auth via x-internal-key header (min 32 chars)
INTERNAL_API_KEY=change_me_to_a_random_secret_min_32_chars

# ---- Meta / WhatsApp Cloud API ----
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_VERIFY_TOKEN=your_custom_verify_token
META_CONFIG_ID=your_facebook_login_config_id
META_GRAPH_VERSION=v21.0
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token
# System User ID from your Meta Business Manager (for permanent tokens)
# Create in: business.facebook.com → Settings → System Users
SYSTEM_USER_ID=

# ---- Frontend (Next.js Dashboard) ----
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_WA_SERVICE_URL=http://localhost:3002/api/v1
NEXT_PUBLIC_META_APP_ID=your_meta_app_id
NEXT_PUBLIC_META_CONFIG_ID=your_facebook_login_config_id
# Solution ID from Meta Partner Center (required for Tech Provider Embedded Signup)
NEXT_PUBLIC_META_SOLUTION_ID=
# Your Tech Provider Business ID (from Meta Business Manager → Settings → Business Info)
NEXT_PUBLIC_META_BUSINESS_ID=

# ---- Google OAuth ----
GOOGLE_OAUTH_CLIENT_ID=

# ---- AI Providers (at least one required) ----
# The LLM Router auto-selects available providers. Unconfigured ones are skipped.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=

# ---- RAG / Embeddings ----
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ---- Production Only ----
# CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token

# ============================================
# Parallext Engine — Environment Variables
# Copy this file as .env and fill in the values
# ============================================

# ---- General ----
NODE_ENV=development
LOG_LEVEL=debug

# ---- Authentication ----
# Shared JWT secret between API and WhatsApp services
INTERNAL_JWT_SECRET=your_jwt_secret_here_min_32_chars

# ---- Database ----
DATABASE_URL=postgresql://parallext:parallext_secret@localhost:5432/parallext_engine

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- API Service (port 3000) ----
API_PORT=3000
DASHBOARD_URL=http://localhost:3001

# ---- WhatsApp Service (port 3002) ----
WA_PORT=3002
ENCRYPTION_KEY=your_64_char_hex_encryption_key_here

# ---- Meta / WhatsApp Cloud API ----
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_VERIFY_TOKEN=your_custom_verify_token
META_CONFIG_ID=your_facebook_login_config_id
META_GRAPH_VERSION=v21.0

# ---- Frontend (Next.js Dashboard) ----
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_WA_SERVICE_URL=http://localhost:3002/api/v1
NEXT_PUBLIC_META_APP_ID=your_meta_app_id
NEXT_PUBLIC_META_CONFIG_ID=your_facebook_login_config_id

# ---- AI Providers (at least one required) ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=

# ---- Production Only ----
# DB_PASSWORD=your_production_db_password
# CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token

# ============================================
# Parallext Engine - Environment Configuration
# ============================================

# ---- Application ----
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
DASHBOARD_URL=http://localhost:3001

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql://parallext:p4r4ll3xt9877*.@localhost:5432/parallext_engine
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=parallext
DATABASE_PASSWORD=p4r4ll3xt9877*.
DATABASE_NAME=parallext_engine

# ---- Redis ----
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- Authentication ----
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ---- LLM Providers ----
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GOOGLE_AI_API_KEY=your-google-ai-key
XAI_API_KEY=your-xai-grok-key
DEEPSEEK_API_KEY=your-deepseek-key

# ---- Embeddings ----
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ---- WhatsApp (Meta Cloud API) ----
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_APP_SECRET=your-meta-app-secret

# ---- Cloudflare R2 (Object Storage) ----
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=parallext-media
R2_PUBLIC_URL=https://media.parallext.com

# ---- Chatwoot ----
CHATWOOT_BASE_URL=https://chatwoot.parallly-chat.cloud
CHATWOOT_API_KEY=your-chatwoot-api-key

# ---- Encryption ----
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# ---- Backup ----
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *

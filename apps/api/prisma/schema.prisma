// Parallext Engine - Prisma Schema
// Multi-tenant platform with schema-per-tenant strategy

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_DATABASE_URL")
  extensions = [pgvector(map: "vector"), uuid_ossp(map: "uuid-ossp")]
  schemas    = ["public"]
}

// ============================================
// PUBLIC SCHEMA — Global tables
// ============================================

// ---- Tenants (Client businesses) ----
model Tenant {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  industry    String
  language    String   @default("es-CO")
  schemaName  String   @unique @map("schema_name")
  isActive    Boolean  @default(true) @map("is_active")
  plan        String   @default("starter")
  settings    Json     @default("{}")

  // Billing — denormalized hot-path fields. Source of truth for full
  // subscription state is the BillingSubscription row linked via the
  // one-to-one relation below. These columns exist so the rate limiter and
  // middleware can decide access without joining billing_subscriptions per
  // request. Kept in sync by BillingService on every state transition.
  billingEmail              String?   @map("billing_email")
  billingCountry            String?   @map("billing_country")
  subscriptionStatus        String?   @map("subscription_status")       // pending_auth|trialing|active|past_due|cancelled|expired
  trialEndsAt               DateTime? @map("trial_ends_at")
  currentPeriodEnd          DateTime? @map("current_period_end")
  paymentProvider           String?   @map("payment_provider")           // mercadopago|stripe|mock
  paymentProviderCustomerId String?   @map("payment_provider_customer_id")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users             User[]
  channelAccounts   ChannelAccount[]
  subscription      BillingSubscription?

  @@map("tenants")
  @@schema("public")
}

// ---- Users (Platform users: admins, agents) ----
model User {
  id                  String   @id @default(uuid())
  email               String   @unique
  password            String?
  firstName           String   @map("first_name")
  lastName            String   @map("last_name")
  role                String   @default("tenant_agent")
  tenantId            String?  @map("tenant_id")
  isActive            Boolean  @default(true) @map("is_active")
  authProvider        String   @default("email") @map("auth_provider")
  googleId            String?  @map("google_id")
  microsoftId         String?  @map("microsoft_id")
  picture             String?
  emailVerified       Boolean  @default(false) @map("email_verified")
  emailVerifyCode     String?  @map("email_verify_code")
  emailVerifyExpires  DateTime? @map("email_verify_expires")
  onboardingCompleted Boolean  @default(false) @map("onboarding_completed")
  phone               String?
  jobTitle            String?  @map("job_title")
  availabilityStatus  String   @default("offline") @map("availability_status")
  maxCapacity         Int      @default(5) @map("max_capacity")
  lastActiveAt        DateTime? @map("last_active_at")
  lastLoginAt         DateTime? @map("last_login_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("users")
  @@schema("public")
}

// ---- Channel Accounts (WhatsApp numbers, IG accounts, etc.) ----
model ChannelAccount {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  channelType   String   @map("channel_type")  // whatsapp, instagram, messenger, telegram
  accountId     String   @map("account_id")     // Phone number / page ID / bot token
  displayName   String   @map("display_name")
  accessToken   String   @map("access_token")   // Encrypted
  refreshToken  String?  @map("refresh_token")  // Encrypted
  webhookSecret String?  @map("webhook_secret")
  isActive      Boolean  @default(true) @map("is_active")
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @map("updated_at")

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([channelType, accountId])
  @@index([tenantId])
  @@map("channel_accounts")
  @@schema("public")
}

// ---- Audit Log ----
model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  tenantId  String?  @map("tenant_id")
  action    String
  resource  String
  details   Json     @default("{}")
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@index([userId])
  @@map("audit_logs")
  @@schema("public")
}

// ---- WhatsApp Onboarding ----
model WhatsappOnboarding {
  id                      String    @id @default(uuid())
  tenantId                String    @map("tenant_id")
  configId                String    @map("config_id")
  mode                    String    @default("new")      // new, existing, coexistence
  status                  String    @default("CREATED")   // OnboardingStatus enum
  isCoexistence           Boolean   @default(false) @map("is_coexistence")
  coexistenceAcknowledged Boolean   @default(false) @map("coexistence_acknowledged")

  // Meta assets discovered
  metaBusinessId          String?   @map("meta_business_id")
  wabaId                  String?   @map("waba_id")
  phoneNumberId           String?   @map("phone_number_id")
  displayPhoneNumber      String?   @map("display_phone_number")
  verifiedName            String?   @map("verified_name")

  // Exchange data
  exchangePayload         Json?     @map("exchange_payload")

  // Error tracking
  errorCode               String?   @map("error_code")
  errorMessage            String?   @map("error_message")

  // Who started the onboarding
  startedByUserId         String?   @map("started_by_user_id")

  // Timestamps
  codeReceivedAt          DateTime? @map("code_received_at")
  exchangeCompletedAt     DateTime? @map("exchange_completed_at")
  assetsSyncedAt          DateTime? @map("assets_synced_at")
  webhookValidatedAt      DateTime? @map("webhook_validated_at")
  completedAt             DateTime? @map("completed_at")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([status])
  @@map("whatsapp_onboardings")
  @@schema("public")
}

// ---- WhatsApp Credentials (encrypted) ----
model WhatsappCredential {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  credentialType  String   @map("credential_type")     // system_user_token, app_secret
  encryptedValue  String   @map("encrypted_value")     // AES-256-GCM encrypted
  rotationState   String   @default("active") @map("rotation_state")  // active, rotating, revoked
  expiresAt       DateTime? @map("expires_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([tenantId, credentialType])
  @@map("whatsapp_credentials")
  @@schema("public")
}

// ============================================
// BILLING — Global tables (cross-tenant)
// ============================================

// ---- Billing Plans ----
// Catalog of subscription tiers. Prices stored in USD cents (source of truth);
// per-country local currency equivalents live in priceLocalOverrides JSONB:
//   { "AR": { "currency": "ARS", "amountCents": 4890000 }, "MX": { ... } }
// Provider-specific plan IDs (MercadoPago preapproval_plan_id, Stripe price_id)
// are populated after creating the plan on each provider.
model BillingPlan {
  id                    String   @id @default(uuid())
  slug                  String   @unique                                  // starter | pro | enterprise | custom
  name                  String
  priceUsdCents         Int      @map("price_usd_cents")
  trialDays             Int      @default(0) @map("trial_days")
  requiresCardForTrial  Boolean  @default(false) @map("requires_card_for_trial")
  maxAgents             Int      @map("max_agents")
  maxAiMessages         Int      @map("max_ai_messages")
  features              Json     @default("{}")
  mpPlanId              String?  @map("mp_plan_id")
  stripePlanId          String?  @map("stripe_plan_id")
  priceLocalOverrides   Json     @default("{}") @map("price_local_overrides")
  isActive              Boolean  @default(true) @map("is_active")
  sortOrder             Int      @default(0) @map("sort_order")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  subscriptions         BillingSubscription[]

  @@map("billing_plans")
  @@schema("public")
}

// ---- Billing Subscriptions ----
// One active subscription per tenant (tenantId @unique). Status is our
// normalized SubscriptionStatus enum; each provider adapter translates its
// own vocabulary on read. Lifecycle transitions are orchestrated by
// BillingService — do not mutate status directly.
model BillingSubscription {
  id                        String   @id @default(uuid())
  tenantId                  String   @unique @map("tenant_id")
  planId                    String   @map("plan_id")
  status                    String                                     // pending_auth|trialing|active|past_due|cancelled|expired
  provider                  String                                     // mercadopago|stripe|mock
  providerSubscriptionId    String?  @unique @map("provider_subscription_id")
  providerCustomerId        String?  @map("provider_customer_id")
  trialStartedAt            DateTime? @map("trial_started_at")
  trialEndsAt               DateTime? @map("trial_ends_at")
  currentPeriodStart        DateTime? @map("current_period_start")
  currentPeriodEnd          DateTime? @map("current_period_end")
  cancelAtPeriodEnd         Boolean  @default(false) @map("cancel_at_period_end")
  cancelledAt               DateTime? @map("cancelled_at")
  cancellationReason        String?  @map("cancellation_reason")
  metadata                  Json     @default("{}")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  tenant                    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan                      BillingPlan  @relation(fields: [planId], references: [id], onDelete: Restrict)
  payments                  BillingPayment[]
  events                    BillingEvent[]

  @@index([status])
  @@index([trialEndsAt])
  @@index([currentPeriodEnd])
  @@map("billing_subscriptions")
  @@schema("public")
}

// ---- Billing Events ----
// Append-only log of every normalized billing event BillingService processes.
// Doubles as the idempotency store: (provider, providerEventId) must be unique
// so a webhook redelivery is skipped on the second processing attempt.
model BillingEvent {
  id                    String   @id @default(uuid())
  tenantId              String?  @map("tenant_id")
  subscriptionId        String?  @map("subscription_id")
  provider              String
  providerEventId       String   @map("provider_event_id")
  eventType             String   @map("event_type")                    // BillingEventType enum as string
  payload               Json                                           // raw provider payload for audit
  processedAt           DateTime @default(now()) @map("processed_at")

  subscription          BillingSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@unique([provider, providerEventId])
  @@index([tenantId, processedAt])
  @@index([eventType])
  @@map("billing_events")
  @@schema("public")
}

// ---- Billing Payments ----
// Individual charge history for invoices, dashboard, and fiscal integration.
// amountCents is in the currency stored in `currency` (USD or local).
// invoicePdfUrl and invoiceNumber are populated by the fiscal integration
// (Facturapi / Alegra / Quaderno) in Phase 4 — nullable until then.
model BillingPayment {
  id                        String   @id @default(uuid())
  subscriptionId            String   @map("subscription_id")
  tenantId                  String   @map("tenant_id")
  amountCents               Int      @map("amount_cents")
  currency                  String                                     // USD | ARS | MXN | COP | CLP | PEN | UYU | BRL
  status                    String                                     // succeeded | failed | refunded | pending
  provider                  String
  providerPaymentId         String?  @unique @map("provider_payment_id")
  paidAt                    DateTime? @map("paid_at")
  failureReason             String?  @map("failure_reason")
  invoiceNumber             String?  @map("invoice_number")
  invoicePdfUrl             String?  @map("invoice_pdf_url")
  metadata                  Json     @default("{}")
  createdAt                 DateTime @default(now()) @map("created_at")

  subscription              BillingSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([status])
  @@map("billing_payments")
  @@schema("public")
}

// ============================================
// FINANCIALS — Platform-level SaaS metrics
// ============================================

// ---- Monthly Financial Snapshot (global) ----
model FinancialSnapshot {
  id                    String   @id @default(uuid())
  snapshotMonth         DateTime @unique @map("snapshot_month")
  mrrCents              Int      @default(0) @map("mrr_cents")
  newMrrCents           Int      @default(0) @map("new_mrr_cents")
  expansionMrrCents     Int      @default(0) @map("expansion_mrr_cents")
  contractionMrrCents   Int      @default(0) @map("contraction_mrr_cents")
  churnedMrrCents       Int      @default(0) @map("churned_mrr_cents")
  reactivationMrrCents  Int      @default(0) @map("reactivation_mrr_cents")
  activeCustomers       Int      @default(0) @map("active_customers")
  newCustomers          Int      @default(0) @map("new_customers")
  churnedCustomers      Int      @default(0) @map("churned_customers")
  trialingCustomers     Int      @default(0) @map("trialing_customers")
  trialsStarted         Int      @default(0) @map("trials_started")
  trialsConverted       Int      @default(0) @map("trials_converted")
  revenueCollectedCents Int      @default(0) @map("revenue_collected_cents")
  paymentsSucceeded     Int      @default(0) @map("payments_succeeded")
  paymentsFailed        Int      @default(0) @map("payments_failed")
  llmCostCents          Int      @default(0) @map("llm_cost_cents")
  infraCostCents        Int      @default(0) @map("infra_cost_cents")
  planDistribution      Json     @default("{}") @map("plan_distribution")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("financial_snapshots")
  @@schema("public")
}

// ---- Per-Tenant Monthly Snapshot ----
model TenantFinancialSnapshot {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  snapshotMonth DateTime @map("snapshot_month")
  planSlug      String   @map("plan_slug")
  mrrCents      Int      @default(0) @map("mrr_cents")
  status        String
  revenueCents  Int      @default(0) @map("revenue_cents")
  llmCostCents  Int      @default(0) @map("llm_cost_cents")
  aiMessages    Int      @default(0) @map("ai_messages")
  conversations Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([tenantId, snapshotMonth])
  @@map("tenant_financial_snapshots")
  @@schema("public")
}

// ---- Infrastructure Costs ----
model InfraCost {
  id          String   @id @default(uuid())
  month       DateTime
  category    String
  description String?
  amountCents Int      @map("amount_cents")
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([month, category])
  @@map("infra_costs")
  @@schema("public")
}

// ---- Exchange Rates ----
model ExchangeRate {
  id           String   @id @default(uuid())
  rateDate     DateTime @map("rate_date")
  fromCurrency String   @map("from_currency")
  toCurrency   String   @map("to_currency")
  rate         Decimal
  source       String   @default("manual")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([rateDate, fromCurrency, toCurrency])
  @@map("exchange_rates")
  @@schema("public")
}

// ============================================
// FEATURE REQUESTS — Global board (cross-tenant)
// ============================================
// Single global board: tenants submit and vote on Parallly platform features.
// No per-tenant board — sub-boards add complexity for PYMEs that won't moderate.
// Status workflow: open → under_review → planned → in_progress → shipped | declined
// Ranking: weighted votes by lifetime MRR + recency decay + engagement bonus.

model FeatureRequest {
  id              String   @id @default(uuid())
  title           String
  description     String
  status          String   @default("open")           // open|under_review|planned|in_progress|shipped|declined
  category        String?                              // ai|integrations|analytics|crm|billing|ux|other
  authorUserId    String   @map("author_user_id")
  authorTenantId  String?  @map("author_tenant_id")   // null if super_admin authored
  voteCount       Int      @default(0) @map("vote_count")            // raw count, denormalized for sort
  weightedScore   Float    @default(0) @map("weighted_score")        // ranking score, recomputed nightly
  commentCount    Int      @default(0) @map("comment_count")
  embedding       Unsupported("vector(1536)")?                       // for duplicate detection
  mergedIntoId    String?  @map("merged_into_id")                    // when admin merges duplicates
  shippedAt       DateTime? @map("shipped_at")
  declinedReason  String?  @map("declined_reason")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  votes           FeatureRequestVote[]
  comments        FeatureRequestComment[]
  mergedInto      FeatureRequest?  @relation("MergedRequests", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  duplicates      FeatureRequest[] @relation("MergedRequests")

  @@index([status, weightedScore(sort: Desc)])
  @@index([authorTenantId])
  @@index([category])
  @@map("feature_requests")
  @@schema("public")
}

model FeatureRequestVote {
  id              String   @id @default(uuid())
  requestId       String   @map("request_id")
  userId          String   @map("user_id")
  tenantId        String?  @map("tenant_id")
  createdAt       DateTime @default(now()) @map("created_at")

  request         FeatureRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([requestId, userId])
  @@index([userId])
  @@index([tenantId])
  @@map("feature_request_votes")
  @@schema("public")
}

model FeatureRequestComment {
  id              String   @id @default(uuid())
  requestId       String   @map("request_id")
  userId          String   @map("user_id")
  tenantId        String?  @map("tenant_id")
  body            String
  isAdminReply    Boolean  @default(false) @map("is_admin_reply")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  request         FeatureRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId, createdAt])
  @@map("feature_request_comments")
  @@schema("public")
}

// Subscribers receive email notifications when status changes or admin comments.
// Auto-subscribed on vote and on comment.
model FeatureRequestSubscriber {
  id          String   @id @default(uuid())
  requestId   String   @map("request_id")
  userId      String   @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([requestId, userId])
  @@map("feature_request_subscribers")
  @@schema("public")
}


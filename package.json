{
  "name": "parallext-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant conversational AI platform for sales automation",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "dev:api": "turbo dev --filter=@parallext/api",
    "dev:dashboard": "turbo dev --filter=@parallext/dashboard",
    "build:api": "turbo build --filter=@parallext/api",
    "build:dashboard": "turbo build --filter=@parallext/dashboard",
    "db:migrate": "turbo db:migrate --filter=@parallext/api",
    "db:seed": "turbo db:seed --filter=@parallext/api",
    "docker:dev": "docker compose -f infra/docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f infra/docker/docker-compose.yml down"
  },
  "devDependencies": {
    "turbo": "^2.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.0.0"
}

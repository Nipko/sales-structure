{
  "info": {
    "name": "Parallly API — Complete Collection",
    "_postman_id": "parallly-api-v1",
    "description": "Colección completa de la API de Parallly (Parallext Engine). Incluye Auth, Intake (público), Copilot, Analytics, Pipeline, Inbox, Broadcast, Knowledge y Settings.\n\n## Setup rápido\n1. Crear un environment en Postman con las variables del archivo `parallly.postman_environment.json`\n2. Ejecutar **Auth → Login** para obtener el token\n3. El token se guarda automáticamente en `{{accessToken}}`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://api.parallly-chat.cloud/api/v1", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "tenantId", "value": "", "type": "string" },
    { "key": "leadId", "value": "", "type": "string" },
    { "key": "opportunityId", "value": "", "type": "string" },
    { "key": "conversationId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.success && json.data) {",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "  pm.collectionVariables.set('tenantId', json.data.user?.tenantId || '');",
                  "  pm.test('Login OK', () => pm.expect(json.success).to.be.true);",
                  "  console.log('✅ Token guardado:', json.data.accessToken.substring(0,30) + '...');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@parallly.com\",\n  \"password\": \"Admin1234!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Me (perfil actual)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{}" },
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"agente1@gecko.com\",\n  \"password\": \"Agent1234!\",\n  \"firstName\": \"Carlos\",\n  \"lastName\": \"Roa\",\n  \"role\": \"agent\",\n  \"tenantId\": \"{{tenantId}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
          }
        }
      ]
    },
    {
      "name": "🏢 Tenants",
      "item": [
        {
          "name": "Listar Tenants",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/tenants", "host": ["{{baseUrl}}"], "path": ["tenants"] }
          }
        },
        {
          "name": "Crear Tenant",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.success && json.data?.id) {",
                  "  pm.collectionVariables.set('tenantId', json.data.id);",
                  "  console.log('✅ TenantId guardado:', json.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Gecko Aventura Extrema\",\n  \"slug\": \"gecko\",\n  \"industry\": \"education\",\n  \"language\": \"es\",\n  \"plan\": \"starter\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/tenants", "host": ["{{baseUrl}}"], "path": ["tenants"] }
          }
        },
        {
          "name": "Ver Tenant",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/tenants/{{tenantId}}", "host": ["{{baseUrl}}"], "path": ["tenants", "{{tenantId}}"] }
          }
        }
      ]
    },
    {
      "name": "📥 Intake (PÚBLICO — sin auth)",
      "description": "Módulo de captura de leads desde landing pages. No requiere JWT. Siempre retorna 200.",
      "item": [
        {
          "name": "Capturar Lead desde formulario",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Intake retorna 200 OK', () => pm.expect(pm.response.code).to.equal(200));",
                  "pm.test('Response tiene ok:true', () => {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.ok).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-tenant-id", "value": "{{tenantId}}", "description": "UUID del tenant (requerido)" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Juan\",\n  \"lastName\": \"Pérez\",\n  \"phone\": \"3001234567\",\n  \"email\": \"juan.perez@gmail.com\",\n  \"consent\": true,\n  \"legalVersion\": \"v1.0\",\n  \"utmSource\": \"google\",\n  \"utmMedium\": \"cpc\",\n  \"utmCampaign\": \"curso-ventas-marzo-2026\",\n  \"utmContent\": \"banner-hero\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/intake/lead", "host": ["{{baseUrl}}"], "path": ["intake", "lead"] }
          }
        },
        {
          "name": "Lead con campaña y curso",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-tenant-id", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"María\",\n  \"lastName\": \"López\",\n  \"phone\": \"+573001234568\",\n  \"email\": \"maria@empresa.com\",\n  \"courseId\": \"00000000-0000-0000-0000-000000000001\",\n  \"campaignId\": \"00000000-0000-0000-0000-000000000002\",\n  \"consent\": true,\n  \"legalVersion\": \"v1.0\",\n  \"utmSource\": \"facebook\",\n  \"utmMedium\": \"social\",\n  \"utmCampaign\": \"retargeting-abril\",\n  \"fbclid\": \"IwAR3abc123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/intake/lead", "host": ["{{baseUrl}}"], "path": ["intake", "lead"] }
          }
        },
        {
          "name": "Lead sin consentimiento (debe silenciar y retornar ok)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Siempre retorna 200', () => pm.expect(pm.response.code).to.equal(200));",
                  "var json = pm.response.json();",
                  "pm.test('ok:true aunque falle internamente', () => pm.expect(json.ok).to.be.true);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-tenant-id", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"SinConsentimiento\",\n  \"phone\": \"3009999999\",\n  \"consent\": false\n}"
            },
            "url": { "raw": "{{baseUrl}}/intake/lead", "host": ["{{baseUrl}}"], "path": ["intake", "lead"] }
          }
        },
        {
          "name": "Sin x-tenant-id header",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"SinTenant\",\n  \"phone\": \"3001111111\",\n  \"consent\": true\n}"
            },
            "url": { "raw": "{{baseUrl}}/intake/lead", "host": ["{{baseUrl}}"], "path": ["intake", "lead"] }
          }
        }
      ]
    },
